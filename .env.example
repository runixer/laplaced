# Laplaced Environment Variables
# Copy this file to .env and fill in your values.
# Every key here mirrors a field in internal/config/default.yaml — env vars win.
# Only the three under "Required" are mandatory for a default Telegram setup.

# ============================================================
# Required
# ============================================================

# Telegram bot token (required when transport=telegram)
LAPLACED_TELEGRAM_TOKEN=your_telegram_bot_token_here

# LLM API key (required) — OpenRouter or any OpenAI-compatible gateway
LAPLACED_LLM_API_KEY=your_api_key_here

# Allowed Telegram user IDs (comma-separated) — REQUIRED for Telegram.
# ⚠️ If empty, the bot rejects ALL messages.
LAPLACED_ALLOWED_USER_IDS=123456789,987654321

# ============================================================
# LLM backend (point at any OpenAI-compatible endpoint)
# ============================================================

# Override to use litellm / vLLM / a self-hosted gateway instead of OpenRouter.
# LAPLACED_LLM_BASE_URL=https://openrouter.ai/api/v1

# Image encoding shape: "file" (OpenRouter/Gemini, default) or "openai"
# (image_url/video_url parts, for litellm/vLLM).
# LAPLACED_LLM_IMAGE_INPUT_FORMAT=file

# OpenRouter provider routing (comma-separated; ignored by other backends).
# LAPLACED_LLM_PROVIDER_ORDER=Google,Google AI Studio

# Optional HTTP egress proxy for the LLM client.
# LAPLACED_LLM_PROXY_URL=

# Secrets can also be pulled from HashiCorp Vault, e.g.
# LAPLACED_LLM_API_KEY="vault:secret/laplaced#api_key"
# See docs/architecture/vault-secrets.md.

# ============================================================
# Transport (chat backend)
# ============================================================

# "telegram" (default) or "mattermost" (Mattermost / Time messenger).
# LAPLACED_TRANSPORT=telegram

# --- Telegram webhook mode (optional; long polling is the default) ---
# LAPLACED_TELEGRAM_WEBHOOK_URL=https://your-domain.com
# LAPLACED_TELEGRAM_PROXY_URL=

# --- Mattermost / Time (used when LAPLACED_TRANSPORT=mattermost) ---
# LAPLACED_MATTERMOST_SERVER_URL=https://mattermost.example.com
# LAPLACED_MATTERMOST_BOT_TOKEN=your_mattermost_bot_token
# LAPLACED_MATTERMOST_ALLOWED_USER_IDS=userid1,userid2
# LAPLACED_MATTERMOST_PROXY_URL=
# SSO gating (optional): restrict which auth_service values are trusted.
# LAPLACED_MATTERMOST_TRUSTED_AUTH_SERVICES=saml
# LAPLACED_MATTERMOST_ACCESS_DENIED_MESSAGE=Sign in via corporate SSO first.

# ============================================================
# Database (SQLite default; PostgreSQL optional)
# ============================================================

# LAPLACED_DATABASE_DRIVER=sqlite
# LAPLACED_DATABASE_PATH=data/laplaced.db

# --- PostgreSQL (used when LAPLACED_DATABASE_DRIVER=postgres) ---
# LAPLACED_DATABASE_HOST=postgres.example.com
# LAPLACED_DATABASE_PORT=5432
# LAPLACED_DATABASE_NAME=laplaced
# LAPLACED_DATABASE_USER=laplaced
# LAPLACED_DATABASE_PASSWORD=your_db_password   # always via env, never a committed literal
# LAPLACED_DATABASE_SSLMODE=require

# ============================================================
# Artifacts (files as memory) — local disk by default
# ============================================================

# LAPLACED_ARTIFACTS_ENABLED=true
# LAPLACED_ARTIFACTS_STORAGE_PATH=data/artifacts
# Only save voice messages >= N seconds (0 = save all, -1 = disable voice artifacts).
# LAPLACED_ARTIFACTS_MIN_VOICE_DURATION_SECONDS=300

# --- S3-compatible blob storage (optional; e.g. Yandex Object Storage) ---
# Set endpoint/region/bucket to switch artifact storage from disk to S3.
# LAPLACED_ARTIFACTS_S3_ENDPOINT=https://storage.yandexcloud.net
# LAPLACED_ARTIFACTS_S3_REGION=ru-central1
# LAPLACED_ARTIFACTS_S3_BUCKET=laplaced-artifacts
# LAPLACED_ARTIFACTS_S3_ACCESS_KEY=your_s3_access_key
# LAPLACED_ARTIFACTS_S3_SECRET_KEY=your_s3_secret_key

# ============================================================
# Models (override the defaults from default.yaml)
# ============================================================

# Main chat model and reasoning effort (auto|off|minimal|low|medium|high).
# LAPLACED_AGENTS_CHAT_MODEL=google/gemini-3.5-flash
# LAPLACED_AGENTS_CHAT_THINKING_LEVEL=auto

# Embeddings (1536 dim; changing either re-embeds all stored vectors on startup).
# LAPLACED_EMBEDDING_MODEL=google/gemini-embedding-2
# LAPLACED_EMBEDDING_DIMENSIONS=1536

# Image generation defaults (set agents.image_generator.model to "" to disable).
# LAPLACED_IMAGE_GENERATOR_DEFAULT_ASPECT_RATIO=9:16
# LAPLACED_IMAGE_GENERATOR_DEFAULT_IMAGE_SIZE=1K

# Emoji reactions (LLM-driven; set to false to disable).
# LAPLACED_AGENTS_REACTOR_ENABLED=true

# ============================================================
# Web dashboard (always on; protected by HTTP Basic Auth)
# ============================================================

# LAPLACED_SERVER_PORT=9081
# LAPLACED_SERVER_DEBUG=false
# LAPLACED_AUTH_ENABLED=true
# LAPLACED_AUTH_USERNAME=admin
# Leave the password empty to have one generated and printed at startup.
# LAPLACED_AUTH_PASSWORD=your_secure_password

# ============================================================
# Behavior & misc
# ============================================================

# UI / prompt language: "en" or "ru".
# LAPLACED_BOT_LANGUAGE=en

# Streaming (progressive) replies via message edits (Telegram only).
# LAPLACED_BOT_STREAMING_ENABLED=true

# Log level: debug|info|warn|error.
# LAPLACED_LOG_LEVEL=info

# ============================================================
# Telemetry (OpenTelemetry tracing) — disabled by default
# ============================================================

# LAPLACED_TELEMETRY_ENABLED=false
# LAPLACED_TELEMETRY_EXPORTER=otlp          # "otlp" or "stdout"
# LAPLACED_TELEMETRY_OTLP_ENDPOINT=localhost:4317
# LAPLACED_TELEMETRY_SERVICE_NAME=laplaced
# Record full prompt/response content on spans (debug only; off by default).
# LAPLACED_TELEMETRY_TRACE_CONTENT=false
